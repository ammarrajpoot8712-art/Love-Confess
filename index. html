<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Hafsa ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
overflow:hidden;
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(135deg,#ffd6e7,#ff7eb3);
position:relative;
}

.container{
text-align:center;
z-index:5;
padding:20px;
}

.bear{
font-size:70px;
animation:bounce 1.5s infinite;
}

@keyframes bounce{
0%,100%{transform:translateY(0);}
50%{transform:translateY(-20px);}
}

h1{
font-family:'Dancing Script',cursive;
font-size:55px;
color:white;
margin-top:10px;
}

.subtitle{
font-style:italic;
font-size:20px;
color:white;
margin:20px 0;
}

.bottomText{
margin-top:30px;
font-size:18px;
color:white;
}

.buttons{
display:flex;
justify-content:center;
gap:40px;
margin-top:35px;
}

#yesBtn{
background:linear-gradient(45deg,#ff1e56,#ff5e78);
border:none;
padding:18px 45px;
color:white;
font-size:22px;
border-radius:50px;
cursor:pointer;
transition:.3s;
box-shadow:0 0 20px rgba(255,0,70,.4);
}

#yesBtn:hover{
transform:scale(1.08);
box-shadow:0 0 35px rgba(255,0,70,.8);
}

#noBtn{
background:white;
border:3px solid #ff3366;
padding:12px 28px;
border-radius:40px;
font-size:18px;
cursor:pointer;
color:#ff3366;
position:relative;
}

.heart{
position:fixed;
bottom:-40px;
pointer-events:none;
animation:float linear infinite;
}

@keyframes float{
0%{
transform:translateY(0);
opacity:0;
}
20%{
opacity:1;
}
80%{
opacity:1;
}
100%{
transform:translateY(-120vh);
opacity:0;
}
}

#celebration{
display:none;
position:fixed;
inset:0;
background:linear-gradient(135deg,#ff6fa8,#ff4d88);
justify-content:center;
align-items:center;
flex-direction:column;
z-index:999;
color:white;
text-align:center;
overflow:hidden;
}

#celebration h2{
font-size:70px;
animation:pulse 1s infinite;
font-family:'Dancing Script',cursive;
}

@keyframes pulse{
50%{
transform:scale(1.15);
}
}

.spin{
font-size:90px;
margin:20px;
animation:spin 2s linear infinite;
}

@keyframes spin{
100%{
transform:rotate(360deg);
}
}

#celebration p{
font-size:24px;
max-width:700px;
padding:0 20px;
}

.confetti{
position:fixed;
width:10px;
height:10px;
top:-20px;
animation:fall linear forwards;
}

@keyframes fall{
to{
transform:translateY(120vh) rotate(720deg);
}
}
</style>
</head>

<body>

<div class="container" id="main">

<div class="bear">🐻</div>

<h1>Will You Be My Valentine, Hafsa? ❤️</h1>

<div class="subtitle">
From the moment you came into my life, you've made every day brighter.
Will you make my heart the happiest by being my Valentine?
</div>

<div class="buttons">
<button id="yesBtn">YES ❤️</button>
<button id="noBtn">NO 💔</button>
</div>

<div class="bottomText">
Every love story is beautiful, but ours is my favourite.
</div>

</div>

<div id="celebration">

<h2>Yayyyy!! 💖</h2>

<div class="spin">🎉</div>

<p>
Thank you for saying YES, Hafsa! ❤️<br>
You just made me the happiest person in the world.
</p>

</div>

<script>const noBtn=document.getElementById("noBtn");
const yesBtn=document.getElementById("yesBtn");
const celebration=document.getElementById("celebration");

const messages=[
"Nope, not an option!",
"Try again!",
"You sure about that?",
"Not happening!",
"Think again!"
];

let index=0;

function moveButton(){

const yesRect=yesBtn.getBoundingClientRect();

let x,y;

do{

x=Math.random()*(window.innerWidth-120);

y=Math.random()*(window.innerHeight-60);

}
while(

x<yesRect.right+60 &&
x+120>yesRect.left-60 &&
y<yesRect.bottom+60 &&
y+60>yesRect.top-60

);

noBtn.style.position="fixed";
noBtn.style.left=x+"px";
noBtn.style.top=y+"px";

noBtn.innerText=messages[index];

index=(index+1)%messages.length;

}

noBtn.addEventListener("mouseover",moveButton);
noBtn.addEventListener("click",moveButton);
noBtn.addEventListener("touchstart",function(e){

e.preventDefault();

moveButton();

});

const hearts=[];

function createHeart(){

const heart=document.createElement("div");

heart.className="heart";

heart.innerHTML="❤️";

heart.style.left=Math.random()*100+"vw";

heart.style.fontSize=(20+Math.random()*30)+"px";

heart.style.animationDuration=(4+Math.random()*5)+"s";

document.body.appendChild(heart);

hearts.push(heart);

heart.addEventListener("animationend",()=>{

heart.remove();

});

}

const heartInterval=setInterval(()=>{

if(hearts.length<15){

createHeart();

}

},500);

yesBtn.onclick=function(){

document.getElementById("main").style.display="none";

celebration.style.display="flex";

clearInterval(heartInterval);

document.querySelectorAll(".heart").forEach(h=>h.remove());

for(let i=0;i<120;i++){

const c=document.createElement("div");

c.className="confetti";

c.style.left=Math.random()*100+"vw";

c.style.background=
`hsl(${Math.random()*360},100%,50%)`;

c.style.width=(6+Math.random()*8)+"px";

c.style.height=(6+Math.random()*8)+"px";

c.style.animationDuration=(3+Math.random()*3)+"s";

c.style.animationDelay=Math.random()+"s";celebration.appendChild(c);

setTimeout(()=>{
c.remove();
},7000);

}

};

</script>

</body>
</html>
